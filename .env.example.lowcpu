# Wild Magic low CPU/RAM example.
#
# Copy this file to .env for a gentler local-LLM setup. It keeps a small amount
# of background generation alive, but trims queue depth, token budgets, context
# windows, and model residency. Foreground/player-facing calls keep the stronger
# GPU-friendly default model; CPU/RAM savings come from shrinking the background
# lane. For the most conservative profile, use .env.example.minimalcpu instead.
#
# Ollama server-side variables below only affect a server started after these
# values are present in its environment. If the Ollama tray app is already
# running, quit it before launching the game, or start `ollama serve` from a
# shell that has these variables.

WILDMAGIC_PROVIDER=ollama
WILDMAGIC_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_DIALOGUE_PROVIDER=ollama
WILDMAGIC_DIALOGUE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_TRADE_PROVIDER=ollama
WILDMAGIC_TRADE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_ITEM_PROVIDER=ollama
WILDMAGIC_ITEM_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_CANON_MODEL=qwen3.5:9b-q4_K_M
WILDMAGIC_AGENT_MODEL=qwen3.5:9b-q4_K_M

# Keep town generation, but make it smaller and slower rather than eager/heavy.
WILDMAGIC_TOWN_PROVIDER=ollama
WILDMAGIC_TOWN_MODEL=qwen3:4b
WILDMAGIC_TOWN_NUM_PREDICT=768

# Keep lightweight lore extraction on a tiny model, but skip optional promise
# decoration. Promise mechanics still work without flesh text.
WILDMAGIC_LORE_ENABLED=1
WILDMAGIC_LORE_PROVIDER=ollama
WILDMAGIC_LORE_MODEL=qwen3:1.7b
WILDMAGIC_LORE_NUM_PREDICT=256
WILDMAGIC_FLESH_ENABLED=0

# Keep nearest-first book title/page prewarming, but only one job can be queued
# or running. Broader room/object saturation remains off.
WILDMAGIC_CANON_PREWARM_ENABLED=0
WILDMAGIC_BOOK_TITLES=1
WILDMAGIC_CANON_PREWARM_LIMIT=1
WILDMAGIC_BACKGROUND_CANON_MODEL=qwen3:1.7b
WILDMAGIC_CANON_NUM_PREDICT=512

# Disable experimental LLM prop set-dressing; this is cosmetic and can otherwise
# create extra concurrent background calls. Static procedural props remain.
WILDMAGIC_PROPS_PROVIDER=off

# Smaller foreground requests reduce RAM pressure. Raise these if spell quality
# falls too far on your machine.
WILDMAGIC_OLLAMA_NUM_CTX=8192
WILDMAGIC_OLLAMA_NUM_PREDICT=768
WILDMAGIC_DIALOGUE_NUM_PREDICT=256
WILDMAGIC_TRADE_NUM_PREDICT=192
WILDMAGIC_ITEM_NUM_PREDICT=256
WILDMAGIC_AGENT_NUM_PREDICT=256
WILDMAGIC_OLLAMA_TIMEOUT=600

# Background route: CPU-only, small context, short residency. This intentionally
# trades latency for less resident memory and less GPU contention.
WILDMAGIC_BACKGROUND_OLLAMA_NUM_GPU=0
WILDMAGIC_BACKGROUND_OLLAMA_NUM_CTX=4096
WILDMAGIC_BACKGROUND_OLLAMA_TIMEOUT=900
WILDMAGIC_BACKGROUND_OLLAMA_KEEP_ALIVE=30s

# Foreground model can stay warm a little longer than background, but still not
# indefinitely.
WILDMAGIC_OLLAMA_KEEP_ALIVE=2m

# Keep Ollama from serving multiple requests or resident models at once.
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Optional isolation: uncomment if foreground calls are still blocked by slow
# background work and you can afford a second Ollama server/process. This may
# increase total RAM if both foreground and background models are resident.
# WILDMAGIC_BACKGROUND_OLLAMA_HOST=http://127.0.0.1:11435
