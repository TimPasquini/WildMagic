WILDMAGIC_PROVIDER=ollama
WILDMAGIC_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_DIALOGUE_PROVIDER=ollama
WILDMAGIC_DIALOGUE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_TRADE_PROVIDER=ollama
WILDMAGIC_TRADE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_TOWN_PROVIDER=ollama
WILDMAGIC_TOWN_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_LORE_ENABLED=1
WILDMAGIC_LORE_PROVIDER=ollama
WILDMAGIC_LORE_MODEL=qwen3:1.7b

# Autonomous playtesting command chooser. The game resolver is still controlled by
# --provider / WILDMAGIC_PROVIDER; this model only chooses CLI commands.
WILDMAGIC_AGENT_MODEL=qwen3.5:9b-q4_K_M
WILDMAGIC_AGENT_TEMPERATURE=0.35
WILDMAGIC_AGENT_NUM_PREDICT=256
# Keep this aligned with other urgent foreground calls when the agent shares the same
# model tag, otherwise Ollama may reload the model between agent and resolver calls.
WILDMAGIC_AGENT_OLLAMA_NUM_CTX=16384

# Shared Ollama defaults used by every Ollama-backed provider unless overridden.
WILDMAGIC_OLLAMA_NUM_CTX=16384
WILDMAGIC_OLLAMA_TIMEOUT=300

# Ollama host. Defaults to http://127.0.0.1:11434. Prefer the IPv4 literal over
# "localhost": on Windows "localhost" resolves to IPv6 ::1 first and stalls ~2s per
# request before falling back to IPv4, on top of every call. See docs/MODEL_CONFIG.md.
# WILDMAGIC_OLLAMA_HOST=http://127.0.0.1:11434

# Optional multi-server routing. Leave these unset to use the default 127.0.0.1:11434.
# Urgent calls are wild magic, dialogue, and trade. Background calls are town generation and lore extraction.
# WILDMAGIC_URGENT_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_BACKGROUND_OLLAMA_HOST=http://127.0.0.1:11435
WILDMAGIC_BACKGROUND_OLLAMA_NUM_GPU=0

# More specific overrides also work:
# WILDMAGIC_WILD_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_DIALOGUE_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_TRADE_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_AGENT_OLLAMA_HOST=http://127.0.0.1:11434
# WILDMAGIC_TOWN_OLLAMA_HOST=http://127.0.0.1:11435
# WILDMAGIC_LORE_OLLAMA_HOST=http://127.0.0.1:11435
