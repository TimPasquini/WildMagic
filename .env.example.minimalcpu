# Wild Magic minimal CPU/RAM example.
#
# Copy this file to .env on machines that freeze or swap heavily during play.
# This keeps player-triggered Ollama calls available, but turns almost all
# optional background generation off. Foreground/player-facing calls keep the
# stronger GPU-friendly default model; CPU/RAM savings come from disabling or
# shrinking background work instead.
#
# Ollama server-side variables below only affect a server started after these
# values are present in its environment. If the Ollama tray app is already
# running, quit it before launching the game, or start `ollama serve` from a
# shell that has these variables.

WILDMAGIC_PROVIDER=ollama
WILDMAGIC_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_DIALOGUE_PROVIDER=ollama
WILDMAGIC_DIALOGUE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_TRADE_PROVIDER=ollama
WILDMAGIC_TRADE_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_ITEM_PROVIDER=ollama
WILDMAGIC_ITEM_MODEL=qwen3.5:9b-q4_K_M

WILDMAGIC_CANON_MODEL=qwen3.5:9b-q4_K_M
WILDMAGIC_AGENT_MODEL=qwen3.5:9b-q4_K_M

# Avoid background town LLM work. Towns still exist; they use the deterministic
# mock generator instead of asking Ollama while the player is walking around.
WILDMAGIC_TOWN_PROVIDER=mock

# Disable dialogue lore extraction and promise decoration background calls.
WILDMAGIC_LORE_ENABLED=0
WILDMAGIC_LORE_PROVIDER=mock
WILDMAGIC_FLESH_ENABLED=0

# Disable background canon prewarming, including always-on book title/page work.
# On-demand examine/read can still call the foreground canon provider when the
# player explicitly asks for it.
WILDMAGIC_CANON_PREWARM_ENABLED=0
WILDMAGIC_BOOK_TITLES=0
WILDMAGIC_CANON_PREWARM_LIMIT=0

# Disable experimental LLM prop set-dressing. Static procedural props remain.
WILDMAGIC_PROPS_PROVIDER=off

# Optional secondary spell-outcome classification also stays deterministic.
WILDMAGIC_DEEDS_PROVIDER=off

# Smaller request sizes reduce RAM pressure. Raise these if model quality falls
# too far on your machine.
WILDMAGIC_OLLAMA_NUM_CTX=8192
WILDMAGIC_OLLAMA_NUM_PREDICT=512
WILDMAGIC_DIALOGUE_NUM_PREDICT=192
WILDMAGIC_TRADE_NUM_PREDICT=192
WILDMAGIC_ITEM_NUM_PREDICT=256
WILDMAGIC_CANON_NUM_PREDICT=512
WILDMAGIC_AGENT_NUM_PREDICT=256
WILDMAGIC_OLLAMA_TIMEOUT=600

# Shorter residency lowers idle RAM at the cost of more reload latency.
WILDMAGIC_OLLAMA_KEEP_ALIVE=30s

# Keep Ollama from serving multiple requests or resident models at once.
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
